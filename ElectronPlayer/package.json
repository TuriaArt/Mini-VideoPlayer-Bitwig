{
  "name": "mini-videoplayer",
  "version": "1.0.0",
  "description": "Video/Image player for Bitwig Studio with crossfade",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.turiaart.miniplayer",
    "productName": "Mini Video Player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "renderer.js"
    ]
  }
}